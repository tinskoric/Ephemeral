{
  "name": "Ephemeral - Temporary Bookmarks",
  "version": "1",
  "manifest_version": 3,
  "author": "Tin Skoric",
  "description": "A browser extension for temporarily saving Wikipedia (or other) deep dives.",
  "icons": {
    "64": "icons/icon-64.png",
    "128": "icons/icon-128.png",
    "256": "icons/icon-256.png"
  },
  "action": {
    "default_icon": {
      "64": "icons/icon-64.png",
      "128": "icons/icon-128.png",
      "256": "icons/icon-256.png"
    },
    "default_title": "Ephemeral",
    "default_popup": "panel/panel.html"
  },
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "alarms",
    "contextMenus",
    "storage"
  ],
  "options_ui": {
    "page": "options/options.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ephemeral@tin.addons.mozilla.org",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      },
    "strict_min_version": "58.0"
    }
  }
}
